{
  "buildCommand": "VITE_API_URL=https://organic-heritage.onrender.com/api npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' *.vercel.app"
        }
      ]
    }
  ]
}